{
  "name": "callingclaw",
  "description": "CallingClaw 2.0 — Voice + Vision + Computer Use AI Agent",
  "module": "src/callingclaw.ts",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "bun run src/callingclaw.ts",
    "dev": "bun --hot run src/callingclaw.ts",
    "setup:python": "pip3 install -r requirements.txt",
    "test": "bun test",
    "eval": "bun eval/run.ts",
    "eval:tool": "bun eval/run.ts --suite tool",
