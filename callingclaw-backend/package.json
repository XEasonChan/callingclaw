    "eval:export": "bun eval/run.ts --export",
    "check": "bun scripts/check-wiring.ts"
  },
  "devDependencies": {
    "@jackwener/opencli": "1.6.1",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "@anthropic-ai/sdk": "^0.78.0",
    "@playwright/cli": "^0.1.1",
    "https-proxy-agent": "^7.0.0",
    "openai": "^6.27.0",
    "ws": "^8.18.0"
  }
}
