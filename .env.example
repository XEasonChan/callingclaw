# CallingClaw — Configuration
#
# Setup: ./scripts/setup.sh (copies this to .env)
# Usage: edit .env, then ./scripts/start.sh

# ─── API Keys ──────────────────────────────────────────────

# OpenAI (REQUIRED — Realtime voice + GPT-4o vision)
OPENAI_API_KEY=sk-xxx

# OpenRouter (RECOMMENDED — Computer Use, analysis, vision)
# OPENROUTER_API_KEY=sk-or-v1-xxx

# Anthropic (OPTIONAL — direct Claude API for Computer Use)
# ANTHROPIC_API_KEY=sk-ant-xxx

# Grok / xAI (OPTIONAL — alternative voice provider, 6x cheaper)
# XAI_API_KEY=xai-xxx

# Gemini 3.1 Flash Live (OPTIONAL — voice + vision, 10x cheaper than OpenAI)
# GOOGLE_AI_API_KEY=AIza...

# Voice provider: openai | grok | gemini (default: grok)
# VOICE_PROVIDER=grok

# ─── Google Calendar (OPTIONAL) ────────────────────────────

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# ─── OpenClaw (OPTIONAL — deep reasoning + meeting prep) ──

# Gateway token (override — defaults to reading from ~/.openclaw/openclaw.json)
# OPENCLAW_GATEWAY_TOKEN=your-token

# ─── CallingClaw Backend ───────────────────────────────────

PORT=4000
SCREEN_WIDTH=1920
SCREEN_HEIGHT=1080

# Your email (for calendar event attendees)
# USER_EMAIL=you@example.com

# Model overrides (advanced)
# ANALYSIS_MODEL=anthropic/claude-haiku-4-5
# SEARCH_MODEL=anthropic/claude-haiku-4-5
# VISION_MODEL=google/gemini-3-flash-preview
