# CallingClaw 2.0 Configuration
# Copy this file to .env and fill in your keys

# OpenAI (REQUIRED — for Realtime voice + GPT-4o vision)
OPENAI_API_KEY=sk-xxx

# Anthropic (OPTIONAL — for Computer Use, direct API)
# ANTHROPIC_API_KEY=sk-ant-xxx

# OpenRouter (RECOMMENDED — alternative for Computer Use, no Anthropic key needed)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxx

# Google OAuth (for Calendar MCP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Server ports
PORT=4000
BRIDGE_PORT=4001

# Screen capture settings
SCREEN_WIDTH=1920
SCREEN_HEIGHT=1080
